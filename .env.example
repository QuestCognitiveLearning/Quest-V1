# =============================================================================
# Quest Learning — environment template
#
# QUICK START
#   1. Copy this file to `.env` (in repo root)
#   2. Fill in real values for the sections marked [LOCAL DEV]
#   3. Run `npm run dev`
#
# WHAT GOES WHERE
#   [LOCAL DEV]    → put in `.env` in the repo root (gitignored).
#                    Used by Vite (frontend dev server) and `npm run import`.
#   [SUPABASE]     → set in the Supabase dashboard under
#                    Project Settings → Edge Functions → Manage secrets.
#                    These are listed here for reference, NOT for local use.
#                    Edge Functions cannot read your local `.env`.
#   [GOOGLE CLOUD] → set in Google Cloud Console → OAuth Client.
#                    Then paste into the Supabase Auth dashboard
#                    (Authentication → Providers → Google).
#
# SECRET HANDLING RULES
#   - `.env` is gitignored. NEVER commit it.
#   - Anything prefixed VITE_ ships in the client bundle. Only put PUBLIC
#     keys (publishable Stripe key, Supabase anon key) under VITE_*.
#   - Rotate any secret that's been pasted into chat, email, or a screenshot.
#   - Use TEST keys for Stripe in dev (sk_test_*). LIVE keys live only in
#     production env, never on a developer machine.
# =============================================================================


# =============================================================================
# [LOCAL DEV] Frontend — required to run `npm run dev`
# =============================================================================

# Your Supabase project URL.
# Get it from: Supabase dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key. Safe to expose in the client bundle — RLS policies protect
# the actual data. Treat it as semi-public, not as a secret.
# Get it from: Supabase dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Where the app runs locally. Used for OAuth redirect URLs.
# In production this becomes https://www.questlearning.co (set in Vercel).
VITE_APP_URL=http://localhost:5173


# =============================================================================
# [LOCAL DEV] One-off CSV import script (server/scripts/import.js)
# Required ONLY if you're seeding the database from CSV exports.
# Skip these unless you're running `npm run import`.
# =============================================================================

# Direct Postgres connection string. Bypasses RLS — use carefully.
# Format: postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres
# Get the password from: Supabase dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Alternative to DATABASE_URL — the import script also accepts just the password.
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# Service-role key — bypasses RLS entirely. Server-side ONLY.
# NEVER expose to the browser. NEVER commit. If accidentally exposed, rotate.
# Get from: Supabase dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...


# =============================================================================
# [SUPABASE] Edge Function secrets — set these in the Supabase dashboard
#
# Path: Project Settings → Edge Functions → Manage secrets → Add new secret
# These are listed here so a new developer knows the full set of secrets
# the deployment needs. Local `.env` does NOT propagate to Edge Functions.
# =============================================================================

# --- OpenAI (LLM + image generation) ---

# OpenAI API key. Used by every LLM call (curriculum gen, Socratic tutor,
# grading, attention checks, image gen).
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optional: default model when a caller doesn't specify one.
# Per-call-site model overrides live in src/lib/llmModels.js — this is the
# catch-all fallback. Leave blank to use the in-code default (gpt-4.1-mini).
OPENAI_MODEL=gpt-4.1-mini


# --- YouTube ---

# YouTube Data API v3. Used by youtubeSearch + duration lookups.
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=AIza...


# --- Video transcripts ---

# TranscriptAPI.io key. Used by fetchTranscript to pull subtitles for the
# attention-check + summary pipelines.
# Get from: https://transcriptapi.io
TRANSCRIPTAPI_KEY=sk_...


# --- Educational standards ---

# Common Standards Project API key. Used by fetchStandards to populate the
# state → subject → grade picker on the curriculum builder.
# Get from: https://commonstandardsproject.com (request key)
COMMON_STANDARDS_API_KEY=...


# --- Stripe (subscriptions) ---

# Secret API key. TEST key (sk_test_*) for dev, LIVE (sk_live_*) for prod.
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — Stripe uses this to sign events sent to our
# stripeWebhook Edge Function. Without it, the webhook ignores all events.
# Get from: https://dashboard.stripe.com/webhooks → click your endpoint →
# Signing secret. The endpoint URL is:
#   https://YOUR-PROJECT-REF.supabase.co/functions/v1/stripeWebhook
STRIPE_WEBHOOK_SECRET=whsec_...


# --- Email (Resend) ---

# Resend API key — used by sendWelcomeEmail, sendEmail, checkDueReviews.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified "from" address. Resend rejects sends from unverified domains.
# Format: "Quest Learning <noreply@yourdomain.com>" or just the email.
EMAIL_FROM=noreply@questlearning.co


# --- Supabase (used inside Edge Functions) ---

# Edge Functions read these from their runtime env, NOT from your local .env.
# Supabase auto-injects SUPABASE_URL, SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY into every Edge Function — you do NOT need to
# add them manually in the dashboard. Listed here for completeness.
#
# SUPABASE_URL                  (auto-injected)
# SUPABASE_ANON_KEY             (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY     (auto-injected)


# =============================================================================
# [GOOGLE CLOUD] OAuth — configure in Google Cloud Console
# =============================================================================
# These are NOT set as env vars. Instead:
#   1. Create OAuth client in: https://console.cloud.google.com/apis/credentials
#   2. Add authorized redirect URI:
#        https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
#   3. Copy Client ID + Client Secret into:
#        Supabase dashboard → Authentication → Providers → Google → enable
# =============================================================================
